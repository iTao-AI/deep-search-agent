# LLM Configuration (DeepSeek official API, OpenAI-compatible)
OPENAI_BASE_URL=https://api.deepseek.com
OPENAI_API_KEY=your-api-key
LLM_MODEL=deepseek-v4-pro
LLM_FALLBACK_MODEL=deepseek-v4-flash
LLM_REASONING_EFFORT=max
LLM_THINKING_MODE=enabled
# Legacy compatibility: used only when LLM_MODEL is not set
# LLM_QWEN_MAX=deepseek-chat

# API Authentication (optional — if not set, all requests accepted without auth)
API_SECRET=your-secret-key

# Tavily Search API (https://app.tavily.com/)
TAVILY_API_KEY=your-tavily-api-key

# LangSmith Tracing (optional, privacy-first)
# Create a workspace-scoped Service Key at https://smith.langchain.com/settings
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=your-workspace-scoped-service-key
LANGSMITH_PROJECT=deep-search-agent-dev
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
# Keep trace structure, timing, metadata, and errors without uploading
# research queries, tool inputs, or generated report content.
LANGSMITH_HIDE_INPUTS=true
LANGSMITH_HIDE_OUTPUTS=true

# MySQL Database
MYSQL_USER=root
MYSQL_PASSWORD=your-mysql-password
MYSQL_DATABASE=your-db-name
MYSQL_HOST=localhost
MYSQL_PORT=3306

# RAGFlow Knowledge Base
RAGFLOW_API_URL=http://localhost:8080
RAGFLOW_API_KEY=your-ragflow-api-key

# Frontend Origin (CORS)
FRONTEND_ORIGIN=http://localhost:5173
