FROM python:3.11-slim

WORKDIR /app

# Install the declared dependencies using the verified compatible versions.
# Avoid pip's HTTP cache in this release image: interrupted Simple API responses
# can poison retry attempts with incomplete index metadata.
COPY requirements.txt constraints.txt ./
RUN python -m pip install --no-cache-dir --default-timeout=60 --retries=5 --upgrade pip && \
    for i in $(seq 1 3); do \
      pip install --no-cache-dir --default-timeout=60 --retries=5 \
        -r requirements.txt -c constraints.txt && break; \
      if [ "$i" -eq 3 ]; then exit 1; fi; \
      echo "pip install attempt $i failed, retrying..." >&2; \
      sleep 5; \
    done

# Copy project source — selective COPY to preserve pip install layer cache
COPY agent/ agent/
COPY api/ api/
COPY prompt/ prompt/
COPY skills/ skills/
COPY tools/ tools/
COPY utils/ utils/
COPY scripts/ scripts/
COPY docs/evidence/durable-hitl-gate-report.json docs/evidence/durable-hitl-gate-report.json

EXPOSE 8000

# Start the FastAPI server
CMD ["uvicorn", "api.server:app", "--host", "0.0.0.0", "--port", "8000"]
