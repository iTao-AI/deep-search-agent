FROM python:3.11-slim

WORKDIR /app

# Install system dependencies required by weasyprint
# Retry logic for flaky mirrors
RUN for i in $(seq 1 3); do \
    apt-get update && \
    apt-get install -y --no-install-recommends \
    gcc \
    libglib2.0-dev \
    libpango1.0-dev \
    libcairo2-dev && \
    break || (echo "Attempt $i failed, retrying..." && sleep 5); \
  done && \
  rm -rf /var/lib/apt/lists/*

# Install the declared dependencies using the verified compatible versions.
# Keep verified downloads across retries so a transient partial response only
# redownloads the failed artifact instead of the full dependency set.
COPY requirements.txt constraints.txt ./
RUN --mount=type=cache,target=/root/.cache/pip \
    for i in $(seq 1 3); do \
      pip install -r requirements.txt -c constraints.txt && break; \
      if [ "$i" -eq 3 ]; then exit 1; fi; \
      echo "pip install attempt $i failed, retrying..." >&2; \
      sleep 5; \
    done

# Copy project source — selective COPY to preserve pip install layer cache
COPY agent/ agent/
COPY api/ api/
COPY prompt/ prompt/
COPY tools/ tools/
COPY utils/ utils/
COPY scripts/ scripts/
COPY docs/evidence/durable-hitl-gate-report.json docs/evidence/durable-hitl-gate-report.json

EXPOSE 8000

# Start the FastAPI server
CMD ["uvicorn", "api.server:app", "--host", "0.0.0.0", "--port", "8000"]
